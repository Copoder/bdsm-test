---
import { CONTACT_EMAIL } from "../data/site";

const isHomepage = Astro.url.pathname === "/";
---

<footer class="site-footer">
  <div class="site-shell footer-grid">
    <div>
      <a class="footer-brand" href="/">BDSMTest.top</a>
      <p>Name the pull. Keep the details yours.</p>
      <div class="featured-badges">
        <a
          class="featured-badge listbulb-badge"
          href="https://www.listbulb.com/tools/bdsmtest"
          target="_blank"
          rel="noopener"
        >
          <img
            src="https://www.listbulb.com/featured-on-listbulb-light.svg"
            alt="Featured on ListBulb"
            height="240"
          />
        </a>
        {isHomepage && (
          <a
            class="featured-badge"
            href="https://toolfame.com/item/bdsm-test"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="https://toolfame.com/badge-light.svg"
              alt="Featured on toolfame.com"
              style="height: 54px; width: auto;"
            />
          </a>
        )}
      </div>
    </div>
    <nav aria-label="Product links">
      <strong>Explore</strong>
      <a href="/methodology/">Methodology</a>
      <a href="/bdsm-roles/">BDSM roles</a>
      <a href="/consent-and-safety/">Consent & safety</a>
    </nav>
    <nav aria-label="Legal links">
      <strong>Trust</strong>
      <a href="/about/">About</a>
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href={`mailto:${CONTACT_EMAIL}`}>Contact</a>
      <a href="https://github.com/Copoder/bdsm-test/issues" rel="noreferrer">Report a correction</a>
    </nav>
  </div>
  <div class="site-shell footer-base">
    <span>For adults 18+ only.</span>
    <span>Not a diagnosis or a substitute for communication.</span>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-7) 0 var(--space-5);
    color: #eee9df;
    background: var(--night);
    border-top: 3px solid var(--oxblood);
  }

  .footer-grid {
    display: grid;
    gap: var(--space-6);
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    text-decoration: none;
  }

  .footer-grid p {
    max-width: 24rem;
    margin: 0.6rem 0 0;
    color: #bdb5aa;
  }

  .featured-badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .featured-badge {
    display: inline-flex;
    text-decoration: none;
    transition: opacity 160ms ease;
  }

  .featured-badge:hover {
    opacity: 0.82;
  }

  .listbulb-badge img {
    width: 11.5rem;
    height: auto;
  }

  .footer-grid nav {
    display: grid;
    align-content: start;
    gap: 0.55rem;
  }

  .footer-grid nav strong {
    margin-bottom: 0.3rem;
    color: white;
    font-size: 0.8rem;
    text-transform: uppercase;
  }

  .footer-grid nav a {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    color: #cec7bd;
    text-decoration: none;
  }

  .footer-base {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-7);
    padding-top: var(--space-4);
    border-top: 1px solid #3c3935;
    color: #9e978e;
    font-size: 0.78rem;
  }

  @media (min-width: 48rem) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
</style>
