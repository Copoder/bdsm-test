---
import { ArrowLeft, ArrowRight, Copy, Download, Ellipsis, ImageDown, Link, QrCode, RotateCcw, Share2, ShieldCheck, Trash2, X } from "@lucide/astro";
---

<section class="test-app" id="start" data-test-app data-state="intro" aria-label="BDSM Test tool">
  <div class="test-frame">
    <div class="shared-view" data-view="shared" hidden>
      <div class="shared-intro">
        <p class="eyebrow">Shared by choice</p>
        <p class="result-kicker">Someone shared this part of their result</p>
        <h2 data-shared-primary>Shared profile</h2>
        <p>You can see their rounded scores, but never their answers, limits, or private boundary map. A shared result is not consent, identity, experience, or compatibility.</p>
        <button class="button shared-cta" type="button" data-action="shared-start">Explore yours privately</button>
      </div>
      <div class="shared-map">
        <section data-shared-role-section>
          <div class="section-title-row"><h2>Shared role scores</h2><span>0–100</span></div>
          <div class="role-score-grid role-score-grid--shared" data-shared-role-results></div>
        </section>
        <details class="shared-dimensions">
          <summary>See the eight preference dimensions</summary>
          <div class="radar-chart radar-chart--shared" data-shared-radar></div>
          <div data-shared-dimensions></div>
        </details>
        <p>The sender's answers, limits, and private boundary map are not included.</p>
      </div>
    </div>

    <div class="intro-view" data-view="intro">
      <div class="intro-atmosphere" aria-hidden="true">
        <img src="/assets/hero-tension.webp" alt="" width="1600" height="900" decoding="async" fetchpriority="high" />
      </div>
      <div class="hero-copy">
        <p class="eyebrow">Private · Adults 18+</p>
        <h1 id="test-heading">Free BDSM Test</h1>
        <p class="hero-hook">What do you crave when it's just you?</p>
        <p class="hero-lede">Control, surrender, restraint, intensity, care, play—follow what lights up. Thirty-two quiet questions. Your answers never leave this device.</p>
        <div class="hero-meta" aria-label="Test details">
          <span><strong>32</strong> questions</span>
          <span><strong>≈5</strong> min</span>
          <span><strong>On-device</strong> only</span>
        </div>
        <div class="intro-actions">
          <button class="button start-button" type="button" data-action="start">Show me what pulls <ArrowRight size={18} /></button>
          <a href="#what-it-measures">Peek at what you'll see</a>
        </div>
        <div class="resume-panel" data-resume hidden>
          <p data-resume-label>Your progress is saved on this device.</p>
          <div>
            <button class="button" type="button" data-action="resume">Continue test</button>
            <button class="button button--secondary" type="button" data-action="restart">Start over</button>
          </div>
        </div>
        <div class="saved-panel" data-saved-result hidden>
          <p>Your latest result is saved on this device.</p>
          <button class="button button--secondary" type="button" data-action="saved-result">View my result</button>
        </div>
        <p class="shared-error" data-shared-error hidden>The shared result link is damaged or no longer supported. You can still take your own test.</p>
      </div>
      <div class="hero-object" aria-hidden="true">
        <div class="tension-ribbon">
          <span class="ribbon-loop ribbon-loop--one"></span>
          <span class="ribbon-loop ribbon-loop--two"></span>
          <span class="ribbon-tail ribbon-tail--one"></span>
          <span class="ribbon-tail ribbon-tail--two"></span>
          <i></i>
        </div>
        <p><span>HOLD</span><em>or</em><span>YIELD?</span></p>
      </div>
    </div>

    <div class="gate-view" data-view="gate" hidden>
      <button class="icon-back" type="button" data-action="gate-back" aria-label="Back to introduction"><ArrowLeft size={22} /></button>
      <div class="gate-content">
        <span class="gate-icon"><ShieldCheck size={26} /></span>
        <p class="eyebrow">Adults only</p>
        <h2>Curious is fine. Consent is required.</h2>
        <p>Answer from fantasy, instinct, or experience. Change any answer anytime. A score is never permission.</p>
        <label class="confirm-row">
          <input type="checkbox" data-confirm="age" />
          <span><strong>I am 18+ and know every scenario assumes reversible consent.</strong><small>Maps appeal—not identity, skill, or permission.</small></span>
        </label>
        <button class="button gate-continue" type="button" data-action="confirm" disabled>Enter the test <ArrowRight size={18} /></button>
        <p class="storage-note" data-storage-note hidden>Private browsing settings prevent progress from surviving a refresh. You can still finish in this tab.</p>
      </div>
    </div>

    <div class="quiz-view" data-view="quiz" hidden>
      <header class="quiz-header">
        <button class="button button--secondary button--icon" type="button" data-action="back" aria-label="Previous question"><ArrowLeft size={21} /></button>
        <div class="quiz-progress-copy">
          <span data-dimension-label>How hard does this pull?</span>
          <strong data-progress-label aria-live="polite">01 / 32</strong>
        </div>
        <button class="button button--secondary button--icon" type="button" data-action="exit" aria-label="Save and exit"><X size={20} /></button>
      </header>
      <div class="progress-track" aria-hidden="true"><span data-progress-bar></span></div>
      <form class="question-form" data-question-form>
        <div class="question-context"><ShieldCheck size={16} /><span>Private mode · Rate the pull</span></div>
        <fieldset>
          <legend data-question-text></legend>
          <p>First instinct. How hard does this pull?</p>
          <div class="answer-list" data-answer-list></div>
        </fieldset>
        <p class="keyboard-note">Keyboard: press 1–5 to answer. Use the back arrow to change a response.</p>
      </form>
    </div>

    <div class="result-view" data-view="result" hidden aria-live="polite">
      <div class="result-header">
        <div class="result-atmosphere" aria-hidden="true">
          <img src="/assets/result-atmosphere.webp" alt="" width="1400" height="1050" decoding="async" />
        </div>
        <div class="result-spotlight">
          <p class="eyebrow">Your private map</p>
          <p class="result-kicker" data-result-kicker>The clearest pull in your answers</p>
          <h2 data-result-primary>Profile</h2>
          <p class="result-match" data-result-match hidden><strong data-result-match-score>0</strong><span>match strength</span></p>
          <p class="result-hook" data-result-hook></p>
          <p class="result-topline" data-result-topline></p>
          <div class="result-spotlight-actions">
            <button class="button" type="button" data-action="scroll-share"><Share2 size={18} /> Share this pull</button>
            <button class="button button--secondary" type="button" data-action="scroll-map">See full map</button>
          </div>
        </div>
      </div>
      <div class="result-reading">
        <p class="result-summary" data-result-summary></p>
        <p class="result-secondary" data-result-secondary hidden></p>
        <p class="result-disclaimer"><strong>Let it land.</strong> This mirrors the pull in today's answers—not a verdict, diagnosis, or fixed identity.</p>
      </div>
      <section class="role-results" id="result-map" aria-labelledby="role-score-heading">
        <div class="section-title-row role-title-row">
          <div><h3 id="role-score-heading">All ten role matches</h3><p>Ranked from highest to lowest for this set of answers.</p></div>
          <span>0–100</span>
        </div>
        <div class="role-score-grid" data-role-results></div>
        <button class="button button--secondary role-toggle" type="button" data-action="toggle-roles" aria-expanded="false">Show all 10 matches</button>
      </section>
      <div class="result-grid">
        <section class="radar-results" aria-labelledby="shape-heading">
          <div class="section-title-row"><h3 id="shape-heading">How your profile takes shape</h3><span>8 dimensions</span></div>
          <div class="radar-chart" data-result-radar></div>
        </section>
        <aside class="result-insights">
          <section>
            <p class="insight-label">Your strongest currents</p>
            <div class="tag-list" data-core-dimensions></div>
          </section>
          <section data-context-section>
            <p class="insight-label">Where context matters</p>
            <div class="tag-list" data-context-dimensions></div>
          </section>
          <section>
            <p class="insight-label">Take this into a conversation</p>
            <ol class="prompt-list" data-communication-prompts></ol>
          </section>
        </aside>
      </div>
      <section class="dimension-results" aria-labelledby="affinity-heading">
        <div class="section-title-row dimension-title-row">
          <div><h3 id="affinity-heading">Category breakdown</h3><p>Ranked by current affinity. Tap a category for context.</p></div>
          <span>0–100</span>
        </div>
        <div data-dimension-results></div>
      </section>
      <section class="share-panel" aria-labelledby="share-heading">
        <div class="share-heading-row">
          <div><p class="insight-label">You decide what travels</p><h3 id="share-heading">Share the shape. Keep the details.</h3></div>
          <Share2 size={26} aria-hidden="true" />
        </div>
        <p>Your profile and rounded scores can travel. Individual answers and your boundary map never do.</p>
        <div class="share-primary-actions">
          <button class="button" type="button" data-action="share-link"><Link size={18} /> Share result link</button>
          <button class="button button--secondary" type="button" data-action="share-image"><ImageDown size={18} /> Share result image</button>
        </div>
        <details class="share-more">
          <summary><Ellipsis size={19} /> More sharing options</summary>
          <div class="share-menu">
            <button type="button" data-action="copy-link"><Copy size={17} /> Copy link</button>
            <button type="button" data-action="copy-text"><Copy size={17} /> Copy result text</button>
            <button type="button" data-action="download-image"><Download size={17} /> Download image</button>
            <button type="button" data-action="show-qr"><QrCode size={17} /> Show QR code</button>
            <a data-share-channel="whatsapp" href="#" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            <a data-share-channel="telegram" href="#" target="_blank" rel="noopener noreferrer">Telegram</a>
            <a data-share-channel="bluesky" href="#" target="_blank" rel="noopener noreferrer">Bluesky</a>
            <a data-share-channel="x" href="#" target="_blank" rel="noopener noreferrer">X</a>
            <a data-share-channel="reddit" href="#" target="_blank" rel="noopener noreferrer">Reddit</a>
            <a data-share-channel="facebook" href="#" target="_blank" rel="noopener noreferrer">Facebook</a>
          </div>
        </details>
        <p class="share-status" data-share-status aria-live="polite"></p>
        <div class="copy-fallback" data-copy-fallback hidden>
          <label for="manual-copy">Select and copy this text</label>
          <div><input id="manual-copy" data-manual-copy readonly /><button type="button" data-action="hide-copy" aria-label="Close manual copy"><X size={17} /></button></div>
        </div>
        <div class="qr-panel" data-qr-panel hidden>
          <button class="qr-close" type="button" data-action="hide-qr" aria-label="Close QR code"><X size={18} /></button>
          <canvas data-qr-canvas width="260" height="260" aria-label="QR code for this shared result"></canvas>
          <p>Scan to open this shared result on another device.</p>
        </div>
      </section>
      <div class="result-actions">
        <button class="button" type="button" data-action="boundary">Map my boundaries</button>
        <button class="button button--secondary" type="button" data-action="scroll-share"><Share2 size={18} /> Share safely</button>
        <button class="button button--secondary" type="button" data-action="retake"><RotateCcw size={18} /> Retake</button>
      </div>
      <section class="boundary-map" data-boundary-map hidden aria-labelledby="boundary-heading">
        <div class="boundary-heading-row">
          <div><p class="insight-label">Saved on this device only</p><h3 id="boundary-heading">Your limits are not your score.</h3></div>
          <button class="button button--secondary button--icon" type="button" data-action="close-boundary" aria-label="Close boundary map"><X size={19} /></button>
        </div>
        <p>Something can be appealing and still be a boundary for practical, emotional, relational, or health reasons. These choices do not change your result and never enter a shared link or image.</p>
        <div class="boundary-list" data-boundary-list></div>
        <div class="boundary-footer">
          <p data-boundary-status aria-live="polite">All categories are optional.</p>
          <button class="button button--secondary" type="button" data-action="clear-boundaries"><Trash2 size={17} /> Clear private map</button>
        </div>
      </section>
    </div>
  </div>
</section>

<script>
  import { initTestApp } from "../lib/test-app";
  document.querySelectorAll<HTMLElement>("[data-test-app]").forEach(initTestApp);
</script>

<style is:global>
  .test-app {
    position: relative;
    min-height: calc(100dvh - 4.5rem);
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(90deg, transparent calc(50% - 0.5px), rgb(124 31 42 / 12%) calc(50% - 0.5px), rgb(124 31 42 / 12%) calc(50% + 0.5px), transparent calc(50% + 0.5px)),
      var(--paper);
  }

  .test-app::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: clamp(1rem, 4vw, 4rem);
    width: 1px;
    background: var(--oxblood);
    opacity: 0.45;
    content: "";
  }

  .test-frame {
    width: min(calc(100% - 2rem), var(--content));
    min-height: inherit;
    margin-inline: auto;
  }

  .intro-view {
    display: grid;
    min-height: inherit;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-7) 0;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 45rem;
  }

  .hero-copy h1 {
    margin-bottom: var(--space-4);
  }

  .hero-lede {
    max-width: 38rem;
    margin-bottom: var(--space-5);
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    margin-bottom: var(--space-6);
    color: var(--ink-soft);
    font-size: 0.84rem;
  }

  .hero-meta strong {
    color: var(--ink);
    font-size: 1rem;
  }

  .intro-actions,
  .resume-panel > div,
  .result-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .intro-actions > a {
    padding: 0.75rem;
    font-weight: 600;
  }

  .start-button {
    min-width: 11.5rem;
  }

  .resume-panel {
    max-width: 34rem;
    margin-top: var(--space-5);
    padding: var(--space-4);
    border: 1px solid var(--line-strong);
    border-left: 3px solid var(--teal);
    background: var(--surface);
  }

  .saved-panel {
    display: flex;
    max-width: 34rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--line);
    background: rgb(255 253 248 / 70%);
  }

  .saved-panel p {
    margin: 0;
    font-size: 0.85rem;
  }

  .shared-error {
    max-width: 36rem;
    margin-top: var(--space-4);
    padding: var(--space-3);
    color: var(--danger);
    border-left: 3px solid currentColor;
    background: rgb(139 39 49 / 6%);
    font-size: 0.84rem;
  }

  .resume-panel p {
    margin-bottom: var(--space-3);
    font-weight: 600;
  }

  .hero-object {
    display: none;
  }

  .tension-disc {
    position: relative;
    width: min(30vw, 21rem);
    aspect-ratio: 1;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .disc-ring {
    position: absolute;
    border: 1px solid var(--line);
    border-radius: 50%;
  }

  .ring-one { inset: 13%; }
  .ring-two { inset: 31%; border-color: var(--ink); }

  .disc-line {
    position: absolute;
    top: -8%;
    left: 50%;
    width: 3px;
    height: 116%;
    background: var(--oxblood);
    transform: rotate(34deg);
    transform-origin: center;
  }

  .disc-pin {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--oxblood);
    transform: translate(-50%, -50%);
  }

  .disc-label {
    position: absolute;
    right: 13%;
    bottom: 17%;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .hero-object p {
    margin: var(--space-4) 0 0;
    color: var(--ink-soft);
    font-family: var(--font-display);
    font-size: 1.15rem;
    text-align: right;
  }

  .gate-view,
  .quiz-view,
  .result-view,
  .shared-view {
    min-height: inherit;
    padding: var(--space-5) 0 var(--space-7);
  }

  .shared-view {
    display: grid;
    align-content: center;
    gap: var(--space-7);
  }

  .shared-intro h2 {
    max-width: 14ch;
    margin-bottom: var(--space-4);
    font-size: 3rem;
  }

  .shared-intro > p:not(.eyebrow, .result-kicker) {
    max-width: 38rem;
    color: var(--ink-soft);
  }

  .shared-cta {
    margin-top: var(--space-3);
  }

  .shared-map {
    align-self: center;
    padding: var(--space-5);
    border: 1px solid var(--line-strong);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .shared-map h2 {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .shared-map > p {
    margin: var(--space-4) 0 0;
    color: var(--steel);
    font-size: 0.75rem;
  }

  .shared-dimensions {
    margin-top: var(--space-4);
    border-top: 1px solid var(--line);
  }

  .shared-dimensions > summary {
    padding: var(--space-3) 0;
    color: var(--ink-soft);
    font-size: 0.8rem;
    font-weight: 650;
    cursor: pointer;
  }

  .gate-view {
    position: relative;
    display: grid;
    place-items: center;
  }

  .icon-back {
    position: absolute;
    top: var(--space-5);
    left: 0;
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: transparent;
    cursor: pointer;
  }

  .gate-content {
    width: min(100%, 40rem);
    padding-top: var(--space-7);
  }

  .gate-icon {
    display: grid;
    width: 3.25rem;
    height: 3.25rem;
    margin-bottom: var(--space-5);
    place-items: center;
    color: var(--teal);
    border: 1px solid var(--teal);
    border-radius: 50%;
  }

  .gate-content h2 {
    margin-bottom: var(--space-4);
  }

  .gate-content > p:not(.eyebrow, .storage-note) {
    color: var(--ink-soft);
  }

  .confirm-row {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--line);
    background: var(--surface);
    cursor: pointer;
  }

  .confirm-row input {
    width: 1.3rem;
    height: 1.3rem;
    margin-top: 0.15rem;
    accent-color: var(--oxblood);
  }

  .confirm-row span,
  .confirm-row small {
    display: block;
  }

  .confirm-row small {
    margin-top: 0.15rem;
    color: var(--ink-soft);
  }

  .gate-continue {
    width: 100%;
    margin-top: var(--space-5);
  }

  .storage-note {
    margin-top: var(--space-3);
    color: var(--warning);
    font-size: 0.84rem;
  }

  .quiz-header {
    display: grid;
    grid-template-columns: 3rem 1fr 3rem;
    align-items: center;
    gap: var(--space-3);
  }

  .quiz-progress-copy {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    font-size: 0.78rem;
  }

  .quiz-progress-copy span { color: var(--ink-soft); }

  .progress-track {
    height: 3px;
    margin-top: var(--space-3);
    background: var(--line);
  }

  .progress-track span {
    display: block;
    width: 3.125%;
    height: 100%;
    background: var(--oxblood);
    transition: width 240ms ease;
  }

  .question-form {
    width: min(100%, 48rem);
    margin: var(--space-6) auto 0;
  }

  .question-context {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    color: var(--teal);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .question-form fieldset {
    padding: 0;
    margin: 0;
    border: 0;
  }

  .question-form legend {
    display: block;
    max-width: 27ch;
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.08;
  }

  .question-form fieldset > p {
    margin-bottom: var(--space-5);
    color: var(--ink-soft);
  }

  .answer-list {
    display: grid;
    gap: 0.55rem;
  }

  .answer-option {
    position: relative;
    display: grid;
    min-height: 3.4rem;
    grid-template-columns: 2rem 1fr;
    align-items: center;
    gap: var(--space-3);
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgb(255 253 248 / 76%);
    cursor: pointer;
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .answer-option:hover {
    border-color: var(--line-strong);
    transform: translateX(2px);
  }

  .answer-option:has(input:checked) {
    border-color: var(--oxblood);
    background: #f4e8e7;
  }

  .answer-option input {
    position: absolute;
    opacity: 0;
  }

  .answer-number {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .answer-option:has(input:checked) .answer-number {
    color: white;
    background: var(--oxblood);
    border-color: var(--oxblood);
  }

  .answer-copy strong {
    display: block;
  }

  .keyboard-note {
    display: none;
    margin: var(--space-3) 0 0;
    color: var(--steel);
    font-size: 0.72rem;
    text-align: center;
  }

  .result-view {
    width: min(100%, 66rem);
    margin-inline: auto;
  }

  .result-header {
    display: grid;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--line-strong);
  }

  .result-spotlight {
    display: grid;
    gap: 0;
    align-content: center;
  }

  .result-kicker {
    margin-bottom: 0.25rem;
    color: var(--ink-soft);
  }

  .result-header h2 {
    max-width: 18ch;
    margin-bottom: var(--space-2);
  }

  .result-match {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    margin: 0 0 var(--space-4);
    color: var(--signal-soft);
    font-family: var(--font-display);
  }

  .result-match strong {
    font-size: clamp(2.4rem, 8vw, 3.6rem);
    font-weight: 500;
    line-height: 1;
    color: var(--paper);
  }

  .result-match span {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #b7afb4;
  }

  .result-hook {
    max-width: 28rem;
    margin: 0 0 var(--space-3);
    color: var(--signal-soft);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3.6vw, 1.85rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.25;
    text-wrap: balance;
  }

  .result-topline {
    max-width: 40rem;
    margin: 0 0 var(--space-4);
    color: #9f979c;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .result-spotlight-actions {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .result-spotlight-actions .button {
    width: 100%;
    justify-content: center;
  }

  .result-reading {
    padding: var(--space-5) 0 var(--space-3);
  }

  .result-summary {
    max-width: 38rem;
    color: var(--ink-soft);
    font-size: 1.02rem;
  }

  .result-secondary {
    margin: var(--space-3) 0 0;
    color: var(--teal);
    font-weight: 600;
  }

  .result-disclaimer {
    margin: var(--space-4) 0 0;
    padding: var(--space-3) var(--space-4);
    color: var(--ink-soft);
    border-left: 3px solid var(--teal);
    background: rgb(56 107 104 / 7%);
    font-size: 0.82rem;
  }

  .role-results {
    padding: var(--space-3) 0 var(--space-5);
  }

  .role-title-row > div > p {
    margin: 0.25rem 0 0;
    color: var(--steel);
    font-size: 0.76rem;
  }

  .role-score-grid {
    display: grid;
    margin-top: var(--space-3);
    border-top: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
  }

  .role-score-row {
    min-width: 0;
    border-right: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    background: rgb(255 253 248 / 76%);
  }

  .role-score-row summary {
    display: grid;
    min-height: 4.65rem;
    grid-template-columns: 2rem minmax(0, 1fr) auto 0.8rem;
    align-content: center;
    align-items: baseline;
    column-gap: var(--space-2);
    padding: 0.7rem 0.8rem;
    cursor: pointer;
    list-style: none;
  }

  .role-score-row summary::-webkit-details-marker { display: none; }

  .role-rank {
    color: var(--steel);
    font-size: 0.68rem;
    font-variant-numeric: tabular-nums;
  }

  .role-score-row summary > strong {
    min-width: 0;
    overflow-wrap: anywhere;
    font-size: 0.86rem;
    line-height: 1.2;
  }

  .role-score-value {
    color: var(--oxblood);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .role-score-toggle {
    color: var(--steel);
    font-size: 1rem;
    line-height: 1;
    text-align: right;
  }

  .role-score-row[open] .role-score-toggle {
    transform: rotate(45deg);
  }

  .role-score-bar {
    display: block;
    height: 0.3rem;
    margin-top: 0.55rem;
    background: var(--paper-deep);
    grid-column: 2 / 5;
  }

  .role-score-bar > span {
    display: block;
    width: var(--role-score);
    height: 100%;
    background: var(--oxblood);
  }

  .role-score-detail {
    padding: 0 var(--space-4) var(--space-4) 3.55rem;
    border-top: 1px solid var(--line);
  }

  .role-score-detail p {
    margin: var(--space-3) 0 var(--space-2);
    color: var(--ink-soft);
    font-size: 0.8rem;
  }

  .role-score-detail small {
    display: block;
    color: var(--steel);
    font-size: 0.72rem;
  }

  .result-grid {
    display: grid;
    gap: var(--space-6);
    padding: var(--space-5) 0;
  }

  .radar-results {
    min-width: 0;
  }

  .radar-chart {
    width: min(100%, 31rem);
    aspect-ratio: 1;
    margin: var(--space-3) auto 0;
  }

  .radar-chart--shared {
    width: min(100%, 23rem);
  }

  .radar-chart svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .radar-grid polygon,
  .radar-grid line {
    fill: none;
    stroke: var(--line-strong);
    stroke-width: 1;
  }

  .radar-grid polygon:nth-child(2) {
    fill: rgb(124 31 42 / 3%);
  }

  .radar-shape {
    fill: rgb(124 31 42 / 26%);
    stroke: var(--oxblood);
    stroke-linejoin: round;
    stroke-width: 2.5;
  }

  .radar-points circle {
    fill: var(--surface);
    stroke: var(--oxblood);
    stroke-width: 2.5;
  }

  .radar-labels text {
    fill: var(--ink-soft);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 650;
  }

  .section-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--line);
  }

  .section-title-row h2,
  .section-title-row h3 { margin: 0; }
  .section-title-row span { color: var(--steel); font-size: 0.75rem; }

  .dimension-results {
    padding: var(--space-3) 0 var(--space-5);
  }

  .dimension-title-row > div > p {
    margin: 0.25rem 0 0;
    color: var(--steel);
    font-size: 0.76rem;
  }

  .dimension-row {
    margin-top: 0.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgb(255 253 248 / 74%);
  }

  .dimension-row summary {
    display: grid;
    min-height: 4.4rem;
    grid-template-columns: minmax(0, 1fr) 1.25rem;
    align-content: center;
    column-gap: var(--space-3);
    padding: 0.8rem 0.9rem;
    cursor: pointer;
    list-style: none;
  }

  .dimension-row summary::-webkit-details-marker { display: none; }

  .dimension-summary-copy {
    display: flex;
    min-width: 0;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .dimension-summary-copy > span {
    overflow-wrap: anywhere;
    font-size: 0.88rem;
    font-weight: 650;
  }

  .dimension-summary-copy strong {
    flex: none;
    color: var(--oxblood);
    font-family: var(--font-display);
    font-size: 1.25rem;
  }

  .dimension-bar {
    display: block;
    height: 0.35rem;
    margin-top: 0.55rem;
    overflow: hidden;
    background: var(--paper-deep);
  }

  .dimension-bar > span {
    display: block;
    width: var(--score);
    height: 100%;
    background: var(--bar-color);
  }

  .dimension-chevron {
    width: 0.55rem;
    height: 0.55rem;
    align-self: center;
    border-right: 1.5px solid var(--ink-soft);
    border-bottom: 1.5px solid var(--ink-soft);
    transform: rotate(45deg);
    transition: transform 160ms ease;
    grid-column: 2;
    grid-row: 1 / 3;
  }

  .dimension-row[open] .dimension-chevron {
    transform: rotate(225deg);
  }

  .dimension-detail {
    padding: 0 var(--space-4) var(--space-4);
    border-top: 1px solid var(--line);
  }

  .dimension-detail p {
    margin: var(--space-3) 0 var(--space-2);
    color: var(--ink-soft);
    font-size: 0.84rem;
  }

  .dimension-detail small {
    display: block;
    color: var(--steel);
    font-size: 0.74rem;
  }

  .result-insights {
    display: grid;
    align-content: start;
    gap: var(--space-5);
  }

  .result-insights section {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--line);
  }

  .insight-label {
    margin-bottom: var(--space-3);
    color: var(--steel);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .tag-list { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .result-tag { padding: 0.35rem 0.6rem; border: 1px solid var(--line-strong); border-radius: 999px; font-size: 0.78rem; }
  .prompt-list { display: grid; gap: var(--space-3); padding-left: 1.2rem; margin: 0; }
  .prompt-list li { padding-left: 0.3rem; }
  .result-actions { padding-top: var(--space-4); border-top: 1px solid var(--line-strong); }
  .share-panel {
    position: relative;
    margin: var(--space-5) 0;
    padding: var(--space-5);
    color: var(--paper);
    background: var(--ink);
    border-top: 3px solid var(--oxblood);
  }

  .share-heading-row,
  .boundary-heading-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .share-panel .insight-label { color: #c98c91; }
  .share-panel h3 { margin-bottom: var(--space-3); color: white; }
  .share-panel > p { max-width: 47rem; color: #beb7ae; }
  .share-primary-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-4); }
  .share-panel .button { color: var(--ink); background: var(--paper); border-color: var(--paper); }
  .share-panel .button:hover { color: white; background: var(--oxblood); border-color: var(--oxblood); }
  .share-panel .button--secondary { color: white; background: transparent; border-color: #756f68; }
  .share-more { margin-top: var(--space-3); }
  .share-more summary { display: inline-flex; min-height: 2.75rem; align-items: center; gap: var(--space-2); color: #d4cdc4; cursor: pointer; font-size: 0.82rem; font-weight: 600; list-style: none; }
  .share-more summary::-webkit-details-marker { display: none; }
  .share-menu { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); margin-top: var(--space-2); border: 1px solid #4a4641; }
  .share-menu button,
  .share-menu a { display: flex; min-height: 3rem; align-items: center; gap: var(--space-2); padding: 0.65rem 0.75rem; color: #eee9df; border: 0; border-right: 1px solid #4a4641; border-bottom: 1px solid #4a4641; background: transparent; text-align: left; text-decoration: none; cursor: pointer; }
  .share-menu button:hover,
  .share-menu a:hover { background: #302d29; }
  .share-status { min-height: 1.4rem; margin: var(--space-3) 0 0 !important; color: #a9c9c5 !important; font-size: 0.78rem; }
  .copy-fallback { margin-top: var(--space-3); padding: var(--space-3); border: 1px solid #5e5851; }
  .copy-fallback label { display: block; margin-bottom: var(--space-2); color: #d4cdc4; font-size: 0.72rem; }
  .copy-fallback > div { display: grid; grid-template-columns: 1fr 2.75rem; }
  .copy-fallback input { min-width: 0; height: 2.75rem; padding: 0 0.65rem; border: 0; color: var(--ink); background: var(--paper); }
  .copy-fallback button { display: grid; place-items: center; border: 0; color: white; background: var(--oxblood); cursor: pointer; }
  .qr-panel { position: relative; width: min(100%, 20rem); margin-top: var(--space-4); padding: var(--space-4); color: var(--ink); background: var(--paper); }
  .qr-panel canvas { width: 100%; height: auto; background: white; }
  .qr-panel p { margin: var(--space-2) 0 0; font-size: 0.74rem; }
  .qr-close { position: absolute; top: 0.3rem; right: 0.3rem; display: grid; width: 2.25rem; height: 2.25rem; place-items: center; border: 1px solid var(--line); background: var(--surface); cursor: pointer; }
  .boundary-map { margin-top: var(--space-5); padding: var(--space-5); border: 1px solid var(--line-strong); background: var(--surface); }
  .boundary-map > p { max-width: 50rem; color: var(--ink-soft); }
  .boundary-list { margin-top: var(--space-5); border-top: 1px solid var(--line-strong); }
  .boundary-row { padding: var(--space-4) 0; border-bottom: 1px solid var(--line); }
  .boundary-copy strong,
  .boundary-copy small { display: block; }
  .boundary-copy small { margin-top: 0.2rem; color: var(--steel); }
  .boundary-options { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.4rem; margin-top: var(--space-3); }
  .boundary-option { position: relative; display: flex; min-height: 2.8rem; align-items: center; justify-content: center; padding: 0.5rem; border: 1px solid var(--line); border-radius: var(--radius); font-size: 0.74rem; text-align: center; cursor: pointer; }
  .boundary-option input { position: absolute; opacity: 0; }
  .boundary-option:has(input:checked) { color: white; background: var(--teal); border-color: var(--teal); }
  .boundary-option:has(input[value="hard"]:checked) { background: var(--oxblood); border-color: var(--oxblood); }
  .boundary-footer { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-3); padding-top: var(--space-4); }
  .boundary-footer p { margin: 0; color: var(--teal); font-size: 0.8rem; }

  /* Private Voltage: dark, self-contained states for exploration and results. */
  .test-app {
    min-height: calc(84svh - 4.5rem);
    color: var(--paper);
    border-color: var(--line-dark);
    background:
      linear-gradient(90deg, transparent calc(50% - 0.5px), rgb(213 88 107 / 14%) calc(50% - 0.5px), rgb(213 88 107 / 14%) calc(50% + 0.5px), transparent calc(50% + 0.5px)),
      var(--night);
  }

  .test-app::before { background: var(--signal); opacity: 0.58; }
  .test-app .eyebrow { color: var(--signal-soft); }

  .intro-view { position: relative; min-height: inherit; padding: 3rem 0 2.5rem; }
  .hero-copy { max-width: 43rem; }
  .hero-copy h1 { margin-bottom: var(--space-5); color: var(--paper); font-size: 3rem; font-weight: 500; }
  .hero-hook { max-width: 16ch; margin: -0.75rem 0 var(--space-4); color: var(--signal-soft); font-family: var(--font-display); font-size: 2rem; font-style: italic; font-weight: 400; line-height: 1.05; }
  .hero-lede { max-width: 35rem; color: #c5bec2; font-size: 1.05rem; }
  .hero-meta { gap: 0; color: #a8a1a6; border-block: 1px solid var(--line-dark); }
  .hero-meta span { padding: 0.75rem 0; }
  .hero-meta span + span { margin-left: 1rem; padding-left: 1rem; border-left: 1px solid var(--line-dark); }
  .hero-meta strong { display: block; color: var(--paper); font-size: 0.95rem; }
  .intro-actions { align-items: stretch; }
  .intro-actions > a { display: inline-flex; min-height: 3.25rem; align-items: center; color: #d8d1d5; }
  .start-button { color: var(--night); background: var(--paper); border-color: var(--paper); }
  .start-button:hover { color: white; background: var(--signal); border-color: var(--signal); }
  .resume-panel { color: var(--paper); border-color: var(--line-dark); border-left-color: var(--teal-light); background: var(--night-raised); }
  .resume-panel .button,
  .saved-panel .button { color: var(--night); background: var(--paper); border-color: var(--paper); }
  .saved-panel { color: var(--paper); border-color: var(--line-dark); background: var(--night-raised); }

  .hero-object { position: absolute; top: 3.5rem; right: -7rem; display: block; opacity: 0.28; pointer-events: none; }
  .tension-disc { width: 16rem; border-color: #655d63; background: transparent; box-shadow: none; }
  .disc-ring { border-color: #655d63; }
  .ring-two { border-color: var(--paper); }
  .disc-line { background: var(--signal); }
  .disc-pin { background: var(--signal); box-shadow: 0 0 0 0.55rem rgb(213 88 107 / 15%); }
  .disc-label { color: var(--paper); }
  .hero-object p { display: none; color: #aaa2a8; }

  .gate-view,
  .quiz-view,
  .shared-view { color: var(--paper); }
  .gate-view { min-height: 100dvh; align-content: end; padding-bottom: max(2rem, env(safe-area-inset-bottom)); }
  .icon-back { top: var(--space-4); color: var(--paper); border-color: var(--line-dark); }
  .gate-content { padding-top: 5.5rem; }
  .gate-content h2 { color: var(--paper); font-size: 2.35rem; }
  .gate-content > p:not(.eyebrow, .storage-note) { color: #bdb6ba; }
  .gate-icon { color: var(--teal-light); border-color: var(--teal-light); }
  .confirm-row { min-height: 4.75rem; border-color: var(--line-dark); background: var(--night-raised); }
  .confirm-row small { color: #aaa3a8; }
  .confirm-row input { accent-color: var(--signal); }
  .gate-continue { color: var(--night); background: var(--paper); border-color: var(--paper); }

  .quiz-view { min-height: 100dvh; padding-top: 0; padding-bottom: calc(6.5rem + env(safe-area-inset-bottom)); }
  .quiz-header { position: sticky; z-index: 10; top: 0; min-height: 4.75rem; padding-block: 0.75rem; background: rgb(16 16 17 / 92%); backdrop-filter: blur(14px); }
  .quiz-header .button--secondary { color: var(--paper); background: transparent; border-color: var(--line-dark); }
  .quiz-progress-copy { align-items: center; color: #a9a1a6; font-size: 0.75rem; text-transform: uppercase; }
  .quiz-progress-copy span { color: #a9a1a6; }
  .quiz-progress-copy strong { color: var(--paper); font-variant-numeric: tabular-nums; }
  .progress-track { height: 2px; margin-top: 0; background: var(--line-dark); }
  .progress-track span { background: var(--signal); }
  .question-form { margin-top: var(--space-5); }
  .question-context { color: var(--teal-light); }
  .question-form legend { color: var(--paper); font-size: 2rem; font-weight: 500; }
  .question-form fieldset > p { color: #aaa3a8; }
  .answer-option { min-height: 3.5rem; color: #d7d1d4; border-color: var(--line-dark); background: var(--night-raised); }
  .answer-option:hover { border-color: #6f666c; background: var(--night-soft); }
  .answer-option:has(input:checked) { color: white; border-color: var(--signal); background: rgb(213 88 107 / 13%); transform: translateX(2px); }
  .answer-number { border-color: #6d656b; color: #b7afb4; }
  .answer-option:has(input:checked) .answer-number { color: var(--night); background: var(--signal-soft); border-color: var(--signal-soft); }
  .question-continue { position: fixed; z-index: 30; right: 1rem; bottom: max(1rem, env(safe-area-inset-bottom)); left: 1rem; width: calc(100% - 2rem); color: var(--night); background: var(--paper); border-color: var(--paper); box-shadow: 0 -1rem 2.5rem rgb(0 0 0 / 35%); }
  .keyboard-note { color: #8f888d; }

  .shared-intro h2 { color: var(--paper); font-size: 3rem; }
  .shared-intro > p:not(.eyebrow, .result-kicker) { color: #bbb4b8; }
  .shared-map { color: var(--paper); border-color: var(--line-dark); background: var(--night-raised); box-shadow: none; }
  .shared-map > p,
  .shared-dimensions > summary { color: #aaa3a8; }

  .test-app[data-state="result"] { min-height: 100dvh; color: var(--ink); border-color: var(--line); background: var(--paper); }
  .test-app[data-state="result"]::before { display: none; }
  .result-view { display: flex; width: min(100%, 66rem); flex-direction: column; padding-top: 0; }
  .result-header { order: 1; width: 100vw; min-height: 72svh; margin-left: calc(50% - 50vw); padding: 4.5rem max(1rem, calc((100vw - 66rem) / 2)); align-items: center; color: var(--paper); border-color: var(--line-dark); background: var(--night); }
  .result-header h2 { color: var(--paper); font-size: 3.2rem; font-weight: 500; }
  .result-kicker { color: #aaa3a8; }
  .result-reading { order: 2; }
  .result-reading .result-summary { color: var(--ink-soft); }
  .result-reading .result-secondary { color: var(--teal); }
  .result-disclaimer { margin: var(--space-4) 0 0; padding: var(--space-3) var(--space-4); border: 0; border-left: 3px solid var(--teal); background: rgb(56 107 104 / 7%); }
  .result-disclaimer strong { display: block; margin-bottom: 0.2rem; color: var(--ink); font-family: var(--font-display); font-size: 1.15rem; }
  .role-results { order: 3; }
  .result-grid { order: 4; }
  .dimension-results { order: 5; }
  .share-panel { order: 6; }
  .result-actions { order: 7; padding-block: var(--space-5); }
  .boundary-map { order: 8; }
  .result-view .role-score-row,
  .result-view .dimension-row { background: rgb(251 248 242 / 78%); }
  .result-view .section-title-row { border-color: var(--line); }
  .result-view .radar-shape { fill: rgb(146 42 62 / 20%); stroke: var(--oxblood); }
  .result-view .radar-points circle { fill: var(--paper); }
  .result-view .result-tag { border-radius: var(--radius); }
  .result-view [data-role-results]:not(.is-expanded) .role-score-row:nth-child(n + 4) { display: none; }
  .role-toggle { width: 100%; margin-top: var(--space-3); }
  .test-app[data-has-resume="true"] .intro-actions,
  .test-app[data-has-result="true"]:not([data-has-resume="true"]) .intro-actions { display: none; }
  .share-panel { background: var(--night-raised); border-color: var(--signal); }
  .boundary-map { background: var(--surface); }

  @media (min-width: 48rem) {
    .hero-copy h1 { font-size: 5.75rem; }
    .hero-hook { font-size: 3.25rem; }
    .hero-lede { font-size: 1.2rem; }
    .hero-object { position: static; display: grid; opacity: 1; }
    .hero-object p { display: block; }
    .tension-disc { width: min(30vw, 21rem); }
