    "deploy": "npm run build && npm run deploy:assets",
    "deploy:assets": "wrangler deploy"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@lucide/astro": "^1.24.0",
    "astro": "^7.0.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/qrcode": "^1.5.6",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
