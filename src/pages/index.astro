---
import { ArrowRight } from "@lucide/astro";
import DimensionGlyph from "../components/DimensionGlyph.astro";
import TestApp from "../components/TestApp.astro";
import { dimensions } from "../data/questions";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "BDSM Test: Free Kink Preference Quiz | BDSMTest.top";
const description = "Take a free, private BDSM test and get scores for 10 BDSM roles plus eight preference dimensions. 32 questions, scored in your browser.";
const faqs = [
  ["What does this BDSM test measure?", "It scores 10 role matches and eight preference dimensions from your answers to 32 negotiated adult scenarios. It does not measure experience, skill, safety knowledge, or identity."],
  ["Is the BDSM test private?", "Yes. Questions, scoring, progress, and results run in your browser. Raw answers are not sent to BDSMTest.top. Shared results contain only the profile and rounded role and preference scores."],
  ["Is this a scientific or diagnostic test?", "No. The model is research-informed but has not yet been validated as a psychometric scale. Treat the result as a structured starting point for reflection and conversation, not a diagnosis."],
  ["Can a result include more than one role?", "Yes. Direction and surrender are scored separately, and closely matched profiles can appear as a blend. A low or diffuse pattern returns Open-ended Explorer instead of forcing a label."],
  ["Does an appealing answer mean I should try it?", "No. Appeal, willingness, practical safety, relationship agreements, and personal boundaries are different questions. Any real activity needs specific, informed, ongoing consent."],
  ["Do I need BDSM experience?", "No. The questions ask about current pull, not past behavior. Choose It depends whenever trust, context, or unfamiliar language matters."]
];
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "BDSM Test",
    url: "https://bdsmtest.top/",
    applicationCategory: "LifestyleApplication",
    operatingSystem: "Any",
    audience: { "@type": "PeopleAudience", requiredMinAge: 18 },
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    description
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(([name, text]) => ({
      "@type": "Question",
      name,
      acceptedAnswer: { "@type": "Answer", text }
    }))
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <TestApp />

  <section class="trust-band" aria-label="Privacy facts">
    <div class="site-shell trust-grid">
      <div><b>01</b><span><strong>You answer</strong>Raw answers stay in this browser</span></div>
      <div><b>02</b><span><strong>Your browser scores</strong>No account or scoring API</span></div>
      <div><b>03</b><span><strong>You choose what leaves</strong>Only a summary when you share</span></div>
    </div>
    <p class="site-shell analytics-note">Ordinary page analytics are separate. They never receive answers, progress, scores, boundaries, or shared-result fragments.</p>
  </section>

  <section class="measure-section site-shell" id="what-it-measures">
    <div class="measure-intro">
      <p class="eyebrow">What this BDSM test reveals</p>
      <h2>A map, not a label</h2>
      <p>See your strongest current role match, all 10 role scores, and eight preference dimensions. The shape matters more than a single winner.</p>
      <a class="text-link" href="/methodology/">Read the scoring method <ArrowRight size={17} /></a>
    </div>
    <div class="example-result" aria-label="Example result chart">
      <div class="example-top"><span>Example scores</span><strong>Result preview</strong></div>
      {dimensions.slice(0, 5).map((dimension, index) => (
        <div class="example-row">
          <span>{dimension.shortName}</span>
          <i><b style={`--example-score:${[78, 62, 45, 53, 70][index]}%;--example-color:${dimension.color}`}></b></i>
          <strong>{[78, 62, 45, 53, 70][index]}</strong>
        </div>
      ))}
      <p>Example only. Your result is calculated after all 32 answers.</p>
    </div>
  </section>

  <section class="dimensions-band">
    <div class="site-shell">
      <div class="section-heading">
        <p class="eyebrow">Eight preference dimensions</p>
        <h2>See the currents beneath the label</h2>
      </div>
      <div class="dimension-grid">
        {dimensions.map((dimension, index) => (
          <article style={`--dimension-color:${dimension.color}`}>
            <div class="dimension-index"><span>{String(index + 1).padStart(2, "0")}</span><DimensionGlyph id={dimension.id} /></div>
            <h3>{dimension.name}</h3>
            <p>{dimension.description}</p>
            <small>{dimension.disclaimer}</small>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="principles-section site-shell">
    <div>
      <p class="eyebrow">How to read the scores</p>
      <h2>Read the result on your terms</h2>
    </div>
    <div class="principle-list">
      <article><span>01</span><div><h3>Appeal is not experience</h3><p>You can be curious without having tried something. The test never infers skill or behavior from attraction.</p></div></article>
      <article><span>02</span><div><h3>Preference is not permission</h3><p>A score never replaces an explicit conversation. Consent stays specific, informed, ongoing, and reversible.</p></div></article>
      <article><span>03</span><div><h3>A result is not identity</h3><p>Profiles summarize this set of answers. They are language for reflection, not a rule about who you must be.</p></div></article>
    </div>
  </section>

  <section class="roles-band">
    <div class="site-shell roles-inner">
      <div>
        <p class="eyebrow">Ten role scores</p>
        <h2>See every role match, not only the winner</h2>
      </div>
      <div>
        <p>Your result ranks every supported role from 0 to 100, then shows the dimensions that shaped those matches. Mixed patterns stay mixed.</p>
        <a class="button button--secondary" href="/bdsm-roles/">Explore BDSM roles <ArrowRight size={17} /></a>
      </div>
    </div>
  </section>

  <section class="safety-section site-shell">
    <div class="safety-mark" aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="reading-width">
      <p class="eyebrow">Built into every scenario</p>
      <h2>Consent is the baseline, not a score</h2>
      <p>Every scenario starts with informed adults, prior negotiation, and the freedom to pause or stop. Communication is required context, never a kink preference.</p>
      <a class="text-link" href="/consent-and-safety/">Read the consent and safety framework <ArrowRight size={17} /></a>
    </div>
  </section>

  <section class="faq-band">
    <div class="site-shell faq-layout">
      <div><p class="eyebrow">Common questions</p><h2>BDSM test FAQ</h2></div>
      <div class="faq-list">
        {faqs.map(([question, answer], index) => (
          <details open={index === 0}>
            <summary>{question}<span aria-hidden="true">+</span></summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta site-shell">
    <p class="eyebrow">Private browser-based scoring</p>
    <h2>Find out what pulls.</h2>
    <a class="button" href="#start">Start privately <ArrowRight size={17} /></a>
  </section>
</BaseLayout>

<style>
  .trust-band { padding-bottom: var(--space-3); border-bottom: 1px solid var(--line-dark); background: var(--night-raised); color: var(--paper); }
  .trust-grid { display: grid; }
  .trust-grid > div { display: grid; min-height: 5.5rem; grid-template-columns: 2rem 1fr; align-items: center; gap: var(--space-3); padding: var(--space-3) 0; border-bottom: 1px solid var(--line-dark); }
  .trust-grid > div:last-child { border-bottom: 0; }
  .trust-grid b { color: var(--signal-soft); font-size: 0.72rem; font-weight: 600; }
  .trust-grid span { display: block; color: #aaa3a8; font-size: 0.78rem; }
  .trust-grid strong { display: block; color: white; font-size: 0.9rem; }
  .analytics-note { margin-block: var(--space-2); color: #888187; font-size: 0.72rem; line-height: 1.45; }
  .measure-section { display: grid; gap: var(--space-7); padding-block: var(--space-8); }
  .measure-intro > p { color: var(--ink-soft); font-size: 1.06rem; }
  .text-link { display: inline-flex; align-items: center; gap: var(--space-2); font-weight: 600; }
  .example-result { align-self: center; padding: var(--space-5); border: 1px solid var(--line-strong); background: var(--surface); box-shadow: var(--shadow); transform: rotate(0.7deg); }
  .example-top { display: flex; justify-content: space-between; margin-bottom: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--line); font-size: 0.75rem; }
  .example-top span { color: var(--steel); text-transform: uppercase; }
  .example-row { display: grid; grid-template-columns: minmax(7rem, 1fr) 2fr 2rem; align-items: center; gap: var(--space-3); padding: 0.65rem 0; font-size: 0.8rem; }
  .example-row i { height: 0.4rem; background: var(--paper-deep); }
  .example-row b { display: block; width: var(--example-score); height: 100%; background: var(--example-color); }
  .example-result > p { margin: var(--space-3) 0 0; color: var(--steel); font-size: 0.72rem; }
  .dimensions-band { padding-block: var(--space-8); background: var(--paper-deep); border-block: 1px solid var(--line); }
  .section-heading { max-width: 46rem; margin-bottom: var(--space-7); }
  .dimension-grid { display: grid; border-top: 1px solid var(--line-strong); }
  .dimension-grid article { padding: var(--space-5) 0; border-bottom: 1px solid var(--line-strong); }
  .dimension-index { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6); color: var(--dimension-color); }
  .dimension-index > span { color: var(--steel); font-size: 0.72rem; }
  .dimension-grid h3 { margin-bottom: var(--space-3); }
  .dimension-grid p { color: var(--ink-soft); }
  .dimension-grid small { display: block; color: var(--steel); line-height: 1.5; }
  .principles-section { display: grid; gap: var(--space-7); padding-block: var(--space-8); }
  .principle-list article { display: grid; grid-template-columns: 3rem 1fr; gap: var(--space-4); padding: var(--space-5) 0; border-top: 1px solid var(--line); }
  .principle-list article > span { color: var(--oxblood); font-size: 0.75rem; }
  .principle-list h3 { margin-bottom: var(--space-2); }
  .principle-list p { margin: 0; color: var(--ink-soft); }
  .roles-band { padding-block: var(--space-8); color: var(--paper); background: var(--night); }
  .roles-inner { display: grid; gap: var(--space-6); }
  .roles-band .eyebrow { color: #d47b84; }
  .roles-band p { color: #bdb6ad; }
  .roles-band .button--secondary { color: white; border-color: #77716a; }
  .roles-band .button--secondary:hover { color: var(--ink); }
  .safety-section { position: relative; display: grid; gap: var(--space-7); padding-block: var(--space-8); }
  .safety-mark { display: grid; width: min(18rem, 70vw); aspect-ratio: 1; place-items: center; border: 1px solid var(--line-strong); border-radius: 50%; }
  .safety-mark span { grid-area: 1/1; border: 1px solid var(--teal); border-radius: 50%; }
  .safety-mark span:nth-child(1) { width: 70%; height: 70%; }
  .safety-mark span:nth-child(2) { width: 42%; height: 42%; }
  .safety-mark span:nth-child(3) { width: 0.8rem; height: 0.8rem; background: var(--teal); }
  .safety-section .reading-width > p:not(.eyebrow) { color: var(--ink-soft); font-size: 1.08rem; }
  .faq-band { padding-block: var(--space-8); background: var(--surface); border-block: 1px solid var(--line); }
  .faq-layout { display: grid; gap: var(--space-6); }
  .faq-list { border-top: 1px solid var(--line-strong); }
  .faq-list details { border-bottom: 1px solid var(--line); }
  .faq-list summary { display: flex; min-height: 4.5rem; align-items: center; justify-content: space-between; gap: var(--space-4); font-weight: 600; cursor: pointer; list-style: none; }
  .faq-list summary::-webkit-details-marker { display: none; }
  .faq-list summary span { color: var(--oxblood); font-size: 1.5rem; font-weight: 400; transition: transform 160ms ease; }
  .faq-list details[open] summary span { transform: rotate(45deg); }
  .faq-list details p { max-width: 44rem; padding: 0 2rem var(--space-5) 0; color: var(--ink-soft); }
  .final-cta { padding-block: var(--space-8); text-align: center; }
  .final-cta .eyebrow { justify-content: center; }
  .final-cta h2 { max-width: 18ch; margin-inline: auto; }
  @media (min-width: 48rem) {
    .trust-grid { grid-template-columns: repeat(3, 1fr); }
    .trust-grid > div { padding: var(--space-3) var(--space-5); border-right: 1px solid #3f3b37; border-bottom: 0; }
    .trust-grid > div:first-child { padding-left: 0; }
    .trust-grid > div:last-child { border-right: 0; }
    .measure-section { grid-template-columns: 7fr 5fr; align-items: center; }
    .dimension-grid { grid-template-columns: repeat(4, 1fr); }
    .dimension-grid article { min-height: 18rem; padding: var(--space-5); border-right: 1px solid var(--line-strong); }
    .dimension-grid article:nth-child(4n) { border-right: 0; }
    .principles-section { grid-template-columns: 5fr 7fr; }
    .roles-inner { grid-template-columns: 7fr 5fr; align-items: end; }
    .safety-section { grid-template-columns: 5fr 7fr; align-items: center; }
    .faq-layout { grid-template-columns: 4fr 8fr; }
  }

  /* Let spacing and contrast create hierarchy instead of a page-wide rule grid. */
  .trust-grid { gap: var(--space-4); padding-top: var(--space-3); }
  .trust-grid > div { border: 0; }
  .dimension-grid { gap: var(--space-6) var(--space-7); border: 0; }
  .dimension-grid article { min-height: 0; padding: 0 0 var(--space-5); border: 0; }
  .dimension-index { margin-bottom: var(--space-4); }
  .example-result { border: 0; box-shadow: 0 1.4rem 3.8rem rgb(20 12 17 / 13%); }

  @media (min-width: 48rem) {
    .trust-grid > div { padding-inline: 0; border: 0; }
    .dimension-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .dimension-grid article { min-height: 13rem; padding: var(--space-4) 0 var(--space-5); border: 0; }
  }
</style>
