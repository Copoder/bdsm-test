---
import { ArrowLeft, ArrowRight, Check, Copy, Download, Ellipsis, ImageDown, Link, QrCode, RotateCcw, Share2, ShieldCheck, Trash2, X } from "@lucide/astro";
---

<section class="test-app" id="start" data-test-app data-state="intro" aria-label="BDSM Test tool">
  <div class="test-frame">
    <div class="shared-view" data-view="shared" hidden>
      <div class="shared-intro">
        <p class="eyebrow">A BDSM Test result was shared with you</p>
        <p class="result-kicker">Their best profile match</p>
        <h2 data-shared-primary>Shared profile</h2>
        <p>These are the scores they chose to share. They are not proof of identity, experience, or consent.</p>
        <button class="button shared-cta" type="button" data-action="shared-start">Take your own BDSM Test</button>
      </div>
      <div class="shared-map">
        <section data-shared-role-section>
          <div class="section-title-row"><h2>Shared role scores</h2><span>0–100</span></div>
          <div class="role-score-grid role-score-grid--shared" data-shared-role-results></div>
        </section>
        <details class="shared-dimensions">
          <summary>See the eight preference dimensions</summary>
          <div class="radar-chart radar-chart--shared" data-shared-radar></div>
          <div data-shared-dimensions></div>
        </details>
        <p>The sender's answers, limits, and private boundary map are not included.</p>
      </div>
    </div>

    <div class="intro-view" data-view="intro">
      <div class="hero-copy">
        <p class="eyebrow">Private by design · Adults 18+</p>
        <h1 id="test-heading">Free BDSM Test</h1>
        <p class="hero-lede">Answer 32 questions and get scores for 10 BDSM roles and eight preference dimensions. No account required; scoring stays in your browser.</p>
        <div class="hero-meta" aria-label="Test details">
          <span><strong>32</strong> questions</span>
          <span><strong>4–6</strong> minutes</span>
          <span><strong>100%</strong> local scoring</span>
        </div>
        <div class="intro-actions">
          <button class="button start-button" type="button" data-action="start">Start the test</button>
          <a href="#what-it-measures">See what it measures</a>
        </div>
        <div class="resume-panel" data-resume hidden>
          <p>You have an unfinished test on this device.</p>
          <div>
            <button class="button" type="button" data-action="resume">Resume</button>
            <button class="button button--secondary" type="button" data-action="restart">Start over</button>
          </div>
        </div>
        <div class="saved-panel" data-saved-result hidden>
          <p>Your latest result is saved on this device.</p>
          <button class="button button--secondary" type="button" data-action="saved-result">View my result</button>
        </div>
        <p class="shared-error" data-shared-error hidden>The shared result link is damaged or no longer supported. You can still take your own test.</p>
      </div>
      <div class="hero-object" aria-hidden="true">
        <div class="tension-disc">
          <span class="disc-ring ring-one"></span>
          <span class="disc-ring ring-two"></span>
          <span class="disc-line"></span>
          <span class="disc-pin"></span>
          <span class="disc-label">01—08</span>
        </div>
        <p>10 role scores.<br/>8 preference dimensions.</p>
      </div>
    </div>

    <div class="gate-view" data-view="gate" hidden>
      <button class="icon-back" type="button" data-action="gate-back" aria-label="Back to introduction"><ArrowLeft size={22} /></button>
      <div class="gate-content">
        <span class="gate-icon"><ShieldCheck size={26} /></span>
        <p class="eyebrow">Before you begin</p>
        <h2>Two things before you start</h2>
        <p>The questions ask what appeals to you now. They do not test experience, skill, identity, consent knowledge, or compatibility.</p>
        <label class="confirm-row">
          <input type="checkbox" data-confirm="age" />
          <span><strong>I am 18 or older.</strong><small>This tool is intended only for adults.</small></span>
        </label>
        <label class="confirm-row">
          <input type="checkbox" data-confirm="context" />
          <span><strong>I understand what the test assumes.</strong><small>Every question assumes informed consent, prior negotiation, adults only, and the ability to stop.</small></span>
        </label>
        <button class="button gate-continue" type="button" data-action="confirm" disabled>Continue</button>
        <p class="storage-note" data-storage-note hidden>Private browsing settings prevent progress from surviving a refresh. You can still finish in this tab.</p>
      </div>
    </div>

    <div class="quiz-view" data-view="quiz" hidden>
      <header class="quiz-header">
        <button class="button button--secondary button--icon" type="button" data-action="back" aria-label="Previous question"><ArrowLeft size={21} /></button>
        <div class="quiz-progress-copy">
          <span data-dimension-label>Current preferences</span>
          <strong data-progress-label aria-live="polite">1 of 32</strong>
        </div>
        <button class="button button--secondary button--icon" type="button" data-action="next" aria-label="Next question" disabled><ArrowRight size={21} /></button>
      </header>
      <div class="progress-track" aria-hidden="true"><span data-progress-bar></span></div>
      <form class="question-form" data-question-form>
        <div class="question-context"><ShieldCheck size={16} /><span>Informed consent · Prior negotiation · Adults only</span></div>
        <fieldset>
          <legend data-question-text></legend>
          <p>How appealing does this feel to you right now?</p>
          <div class="answer-list" data-answer-list></div>
        </fieldset>
        <p class="keyboard-note">Keyboard: press 1–5 to answer. Use the arrow above to revisit a question.</p>
      </form>
    </div>

    <div class="result-view" data-view="result" hidden aria-live="polite">
      <div class="result-header">
        <div>
          <p class="eyebrow">Your BDSM test result</p>
          <p class="result-kicker">Best profile match</p>
          <h2 data-result-primary>Profile</h2>
          <p class="result-summary" data-result-summary></p>
          <p class="result-secondary" data-result-secondary hidden></p>
        </div>
        <div class="result-seal" aria-hidden="true"><Check size={28} /><span>LOCAL<br/>RESULT</span></div>
      </div>
      <p class="result-disclaimer">Role scores show how closely your answers match this test's formulas. They are not population percentiles or fixed identities.</p>
      <section class="role-results" aria-labelledby="role-score-heading">
        <div class="section-title-row role-title-row">
          <div><h3 id="role-score-heading">Your role scores</h3><p>All ten matches, ranked from highest to lowest.</p></div>
          <span>0–100</span>
        </div>
        <div class="role-score-grid" data-role-results></div>
      </section>
      <div class="result-grid">
        <section class="radar-results" aria-labelledby="shape-heading">
          <div class="section-title-row"><h3 id="shape-heading">Why these roles matched</h3><span>8 dimensions</span></div>
          <div class="radar-chart" data-result-radar></div>
        </section>
        <aside class="result-insights">
          <section>
            <p class="insight-label">Highest dimensions</p>
            <div class="tag-list" data-core-dimensions></div>
          </section>
          <section data-context-section>
            <p class="insight-label">Context-sensitive dimensions</p>
            <div class="tag-list" data-context-dimensions></div>
          </section>
          <section>
            <p class="insight-label">Questions to discuss</p>
            <ol class="prompt-list" data-communication-prompts></ol>
          </section>
        </aside>
      </div>
      <section class="dimension-results" aria-labelledby="affinity-heading">
        <div class="section-title-row dimension-title-row">
          <div><h3 id="affinity-heading">Category breakdown</h3><p>Ranked by current affinity. Tap a category for context.</p></div>
          <span>0–100</span>
        </div>
        <div data-dimension-results></div>
      </section>
      <section class="share-panel" aria-labelledby="share-heading">
        <div class="share-heading-row">
          <div><p class="insight-label">Made for sharing</p><h3 id="share-heading">Share your BDSM test result</h3></div>
          <Share2 size={26} aria-hidden="true" />
        </div>
        <p>The link and result image show your profile, role scores, and eight preference scores. They never include individual answers or your private boundary choices.</p>
        <div class="share-primary-actions">
          <button class="button" type="button" data-action="share-link"><Link size={18} /> Share result link</button>
          <button class="button button--secondary" type="button" data-action="share-image"><ImageDown size={18} /> Share result image</button>
        </div>
        <details class="share-more">
          <summary><Ellipsis size={19} /> More sharing options</summary>
          <div class="share-menu">
            <button type="button" data-action="copy-link"><Copy size={17} /> Copy link</button>
            <button type="button" data-action="copy-text"><Copy size={17} /> Copy result text</button>
            <button type="button" data-action="download-image"><Download size={17} /> Download image</button>
            <button type="button" data-action="show-qr"><QrCode size={17} /> Show QR code</button>
            <a data-share-channel="whatsapp" href="#" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            <a data-share-channel="telegram" href="#" target="_blank" rel="noopener noreferrer">Telegram</a>
            <a data-share-channel="bluesky" href="#" target="_blank" rel="noopener noreferrer">Bluesky</a>
            <a data-share-channel="x" href="#" target="_blank" rel="noopener noreferrer">X</a>
            <a data-share-channel="reddit" href="#" target="_blank" rel="noopener noreferrer">Reddit</a>
            <a data-share-channel="facebook" href="#" target="_blank" rel="noopener noreferrer">Facebook</a>
          </div>
        </details>
        <p class="share-status" data-share-status aria-live="polite"></p>
        <div class="copy-fallback" data-copy-fallback hidden>
          <label for="manual-copy">Select and copy this text</label>
          <div><input id="manual-copy" data-manual-copy readonly /><button type="button" data-action="hide-copy" aria-label="Close manual copy"><X size={17} /></button></div>
        </div>
        <div class="qr-panel" data-qr-panel hidden>
          <button class="qr-close" type="button" data-action="hide-qr" aria-label="Close QR code"><X size={18} /></button>
          <canvas data-qr-canvas width="260" height="260" aria-label="QR code for this shared result"></canvas>
          <p>Scan to open this shared result on another device.</p>
        </div>
      </section>
      <div class="result-actions">
        <button class="button" type="button" data-action="boundary">Build a private boundary map</button>
        <button class="button button--secondary" type="button" data-action="retake"><RotateCcw size={18} /> Retake</button>
      </div>
      <section class="boundary-map" data-boundary-map hidden aria-labelledby="boundary-heading">
        <div class="boundary-heading-row">
          <div><p class="insight-label">Saved on this device only</p><h3 id="boundary-heading">Private Boundary Map</h3></div>
          <button class="button button--secondary button--icon" type="button" data-action="close-boundary" aria-label="Close boundary map"><X size={19} /></button>
        </div>
        <p>Something can be appealing and still be a boundary for practical, emotional, relational, or health reasons. These choices do not change your result and never enter a shared link or image.</p>
        <div class="boundary-list" data-boundary-list></div>
        <div class="boundary-footer">
          <p data-boundary-status aria-live="polite">All categories are optional.</p>
          <button class="button button--secondary" type="button" data-action="clear-boundaries"><Trash2 size={17} /> Clear private map</button>
        </div>
      </section>
    </div>
  </div>
</section>

<script>
  import { initTestApp } from "../lib/test-app";
  document.querySelectorAll<HTMLElement>("[data-test-app]").forEach(initTestApp);
</script>

<style is:global>
  .test-app {
    position: relative;
    min-height: calc(100dvh - 4.5rem);
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(90deg, transparent calc(50% - 0.5px), rgb(124 31 42 / 12%) calc(50% - 0.5px), rgb(124 31 42 / 12%) calc(50% + 0.5px), transparent calc(50% + 0.5px)),
      var(--paper);
  }

  .test-app::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: clamp(1rem, 4vw, 4rem);
    width: 1px;
    background: var(--oxblood);
    opacity: 0.45;
    content: "";
  }

  .test-frame {
    width: min(calc(100% - 2rem), var(--content));
    min-height: inherit;
    margin-inline: auto;
  }

  .intro-view {
    display: grid;
    min-height: inherit;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-7) 0;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 45rem;
  }

  .hero-copy h1 {
    margin-bottom: var(--space-4);
  }

  .hero-lede {
    max-width: 38rem;
    margin-bottom: var(--space-5);
    color: var(--ink-soft);
    font-size: clamp(1.08rem, 2vw, 1.3rem);
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    margin-bottom: var(--space-6);
    color: var(--ink-soft);
    font-size: 0.84rem;
  }

  .hero-meta strong {
    color: var(--ink);
    font-size: 1rem;
  }

  .intro-actions,
  .resume-panel > div,
  .result-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .intro-actions > a {
    padding: 0.75rem;
    font-weight: 600;
  }

  .start-button {
    min-width: 11.5rem;
  }

  .resume-panel {
    max-width: 34rem;
    margin-top: var(--space-5);
    padding: var(--space-4);
    border: 1px solid var(--line-strong);
    border-left: 3px solid var(--teal);
    background: var(--surface);
  }

  .saved-panel {
    display: flex;
    max-width: 34rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--line);
    background: rgb(255 253 248 / 70%);
  }

  .saved-panel p {
    margin: 0;
    font-size: 0.85rem;
  }

  .shared-error {
    max-width: 36rem;
    margin-top: var(--space-4);
    padding: var(--space-3);
    color: var(--danger);
    border-left: 3px solid currentColor;
    background: rgb(139 39 49 / 6%);
    font-size: 0.84rem;
  }

  .resume-panel p {
    margin-bottom: var(--space-3);
    font-weight: 600;
  }

  .hero-object {
    display: none;
  }

  .tension-disc {
    position: relative;
    width: min(30vw, 21rem);
    aspect-ratio: 1;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .disc-ring {
    position: absolute;
    border: 1px solid var(--line);
    border-radius: 50%;
  }

  .ring-one { inset: 13%; }
  .ring-two { inset: 31%; border-color: var(--ink); }

  .disc-line {
    position: absolute;
    top: -8%;
    left: 50%;
    width: 3px;
    height: 116%;
    background: var(--oxblood);
    transform: rotate(34deg);
    transform-origin: center;
  }

  .disc-pin {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--oxblood);
    transform: translate(-50%, -50%);
  }

  .disc-label {
    position: absolute;
    right: 13%;
    bottom: 17%;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .hero-object p {
    margin: var(--space-4) 0 0;
    color: var(--ink-soft);
    font-family: var(--font-display);
    font-size: 1.15rem;
    text-align: right;
  }

  .gate-view,
  .quiz-view,
  .result-view,
  .shared-view {
    min-height: inherit;
    padding: var(--space-5) 0 var(--space-7);
  }

  .shared-view {
    display: grid;
    align-content: center;
    gap: var(--space-7);
  }

  .shared-intro h2 {
    max-width: 14ch;
    margin-bottom: var(--space-4);
    font-size: clamp(2.65rem, 8vw, 5.75rem);
  }

  .shared-intro > p:not(.eyebrow, .result-kicker) {
    max-width: 38rem;
    color: var(--ink-soft);
  }

  .shared-cta {
    margin-top: var(--space-3);
  }

  .shared-map {
    align-self: center;
    padding: var(--space-5);
    border: 1px solid var(--line-strong);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .shared-map h2 {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .shared-map > p {
    margin: var(--space-4) 0 0;
    color: var(--steel);
    font-size: 0.75rem;
  }

  .shared-dimensions {
    margin-top: var(--space-4);
    border-top: 1px solid var(--line);
  }

  .shared-dimensions > summary {
    padding: var(--space-3) 0;
    color: var(--ink-soft);
    font-size: 0.8rem;
    font-weight: 650;
    cursor: pointer;
  }

  .gate-view {
    position: relative;
    display: grid;
    place-items: center;
  }

  .icon-back {
    position: absolute;
    top: var(--space-5);
    left: 0;
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: transparent;
    cursor: pointer;
  }

  .gate-content {
    width: min(100%, 40rem);
    padding-top: var(--space-7);
  }

  .gate-icon {
    display: grid;
    width: 3.25rem;
    height: 3.25rem;
    margin-bottom: var(--space-5);
    place-items: center;
    color: var(--teal);
    border: 1px solid var(--teal);
    border-radius: 50%;
  }

  .gate-content h2 {
    margin-bottom: var(--space-4);
  }

  .gate-content > p:not(.eyebrow, .storage-note) {
    color: var(--ink-soft);
  }

  .confirm-row {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--line);
    background: var(--surface);
    cursor: pointer;
  }

  .confirm-row input {
    width: 1.3rem;
    height: 1.3rem;
    margin-top: 0.15rem;
    accent-color: var(--oxblood);
  }

  .confirm-row span,
  .confirm-row small {
    display: block;
  }

  .confirm-row small {
    margin-top: 0.15rem;
    color: var(--ink-soft);
  }

  .gate-continue {
    width: 100%;
    margin-top: var(--space-5);
  }

  .storage-note {
    margin-top: var(--space-3);
    color: var(--warning);
    font-size: 0.84rem;
  }

  .quiz-header {
    display: grid;
    grid-template-columns: 3rem 1fr 3rem;
    align-items: center;
    gap: var(--space-3);
  }

  .quiz-progress-copy {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    font-size: 0.78rem;
  }

  .quiz-progress-copy span { color: var(--ink-soft); }

  .progress-track {
    height: 3px;
    margin-top: var(--space-3);
    background: var(--line);
  }

  .progress-track span {
    display: block;
    width: 3.125%;
    height: 100%;
    background: var(--oxblood);
    transition: width 240ms ease;
  }

  .question-form {
    width: min(100%, 48rem);
    margin: var(--space-6) auto 0;
  }

  .question-context {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    color: var(--teal);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .question-form fieldset {
    padding: 0;
    margin: 0;
    border: 0;
  }

  .question-form legend {
    display: block;
    max-width: 27ch;
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 6vw, 3.25rem);
    font-weight: 600;
    line-height: 1.08;
  }

  .question-form fieldset > p {
    margin-bottom: var(--space-5);
    color: var(--ink-soft);
  }

  .answer-list {
    display: grid;
    gap: 0.55rem;
  }

  .answer-option {
    position: relative;
    display: grid;
    min-height: 3.4rem;
    grid-template-columns: 2rem 1fr;
    align-items: center;
    gap: var(--space-3);
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgb(255 253 248 / 76%);
    cursor: pointer;
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .answer-option:hover {
    border-color: var(--line-strong);
    transform: translateX(2px);
  }

  .answer-option:has(input:checked) {
    border-color: var(--oxblood);
    background: #f4e8e7;
  }

  .answer-option input {
    position: absolute;
    opacity: 0;
  }

  .answer-number {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .answer-option:has(input:checked) .answer-number {
    color: white;
    background: var(--oxblood);
    border-color: var(--oxblood);
  }

  .answer-copy strong {
    display: block;
  }

  .keyboard-note {
    display: none;
    margin: var(--space-3) 0 0;
    color: var(--steel);
    font-size: 0.72rem;
    text-align: center;
  }

  .result-view {
    width: min(100%, 66rem);
    margin-inline: auto;
  }

  .result-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--line-strong);
  }

  .result-kicker {
    margin-bottom: 0.25rem;
    color: var(--ink-soft);
  }

  .result-header h2 {
    max-width: 18ch;
    margin-bottom: var(--space-3);
  }

  .result-summary {
    max-width: 38rem;
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .result-secondary {
    margin: 0;
    color: var(--teal);
    font-weight: 600;
  }

  .result-seal {
    display: none;
  }

  .result-disclaimer {
    margin: var(--space-4) 0;
    padding: var(--space-3) var(--space-4);
    color: var(--ink-soft);
    border-left: 3px solid var(--teal);
    background: rgb(56 107 104 / 7%);
    font-size: 0.82rem;
  }

  .role-results {
    padding: var(--space-3) 0 var(--space-5);
  }

  .role-title-row > div > p {
    margin: 0.25rem 0 0;
    color: var(--steel);
    font-size: 0.76rem;
  }

  .role-score-grid {
    display: grid;
    margin-top: var(--space-3);
    border-top: 1px solid var(--line-strong);
