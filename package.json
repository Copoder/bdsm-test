{
  "name": "bdsm-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "assets": "node scripts/generate-assets.mjs",
    "build": "astro check && astro build && node scripts/postbuild.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
